{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      {
        "include": "**/*.png",
        "outDir": "dist"
      },
      {
        "include": "assets/**/*",
        "outDir": "dist/assets"
      },
      {
        "include": "templates/**/*",
        "outDir": "dist/templates"
      }
    ],
    "watchAssets": true
  }
}
